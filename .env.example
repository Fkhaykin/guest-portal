# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Lodgify
LODGIFY_API_KEY=
LODGIFY_WEBHOOK_SIGNING_SECRETS=  # Comma-separated secrets from Lodgify webhook subscriptions (ms-signature verification)

# Resend (email)
RESEND_API_KEY=
# Signing secret of the Resend "email.received" webhook (direct-booking guest replies)
RESEND_INBOUND_WEBHOOK_SECRET=
# Domain that receives direct-booking email replies (reply+<registration_id>@<domain>)
DIRECT_REPLY_EMAIL_DOMAIN=reply.summitlakeside.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps (for "Getting Here" animated map on guest dashboard)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Twilio (SMS notifications to cleaners)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Cron (Vercel Cron uses this automatically; set for local testing)
CRON_SECRET=

# Anthropic (AI-suggested replies in admin messenger)
ANTHROPIC_API_KEY=

# Web Push (cleaner portal notifications) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
